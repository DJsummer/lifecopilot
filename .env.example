# LifePilot 环境变量配置
# 复制为 .env 并填写真实值: cp .env.example .env

# ── 应用 ──────────────────────────────────────
ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-32-char-string
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── API 端口 ──────────────────────────────────
API_PORT=8000

# ── PostgreSQL ────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=lifepilot
POSTGRES_USER=lifepilot
POSTGRES_PASSWORD=change-me

# ── Redis ─────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# ── InfluxDB ──────────────────────────────────
INFLUX_URL=http://influxdb:8086
INFLUX_USER=admin
INFLUX_PASSWORD=change-me
INFLUX_ORG=lifepilot
INFLUX_BUCKET=health_metrics
INFLUX_TOKEN=change-me-to-a-long-token
INFLUX_PORT=8086

# ── Qdrant ────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── LLM ──────────────────────────────────────
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
